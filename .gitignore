# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node modules
node_modules/

# Yarn & PnP
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Dependency directories
jspm_packages/

# Build output
.next/
out/
build/
dist/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Local env files
.env*
.env.*

# Mac system files
.DS_Store

# Windows system files
Thumbs.db

# VS Code settings
.vscode/

# Coverage directory used by tools like istanbul
coverage/

# Misc
*.tgz
*.swp
*.swo
*.pem

# IDE files
.idea/
*.iml

# Tailwind JIT cache
.tailwindcss*

# Parcel-bundler cache
.cache/

# SASS cache
.sass-cache/

# TypeScript cache
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# Optional: Ignore public/static uploads (uncomment if needed)
# public/uploads/
